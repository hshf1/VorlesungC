{
    "code-runner.runInTerminal": true,
    "code-runner.saveFileBeforeRun": true,
    "code-runner.executorMap": {
        "c": "cd $dir && & \"$workspaceRoot\\compiler\\bin\\gcc.exe\" $fileName -o $fileNameWithoutExt.exe && .\\$fileNameWithoutExt.exe"
    },
    "C_Cpp.default.compilerPath": "${workspaceFolder}/compiler/bin/gcc.exe",
    "C_Cpp.default.intelliSenseMode": "windows-gcc-x64",
    "C_Cpp.default.cStandard": "c89"
}