{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C-Code kompilieren",
            "command": "${workspaceFolder}/compiler/bin/gcc.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}.exe"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Kompiliert die aktuell in VS Code geoeffnete C-Datei."
        }
    ]
}